exports[`StatusMessage snapshots > renders message with retry button 1`] = `
<div
  aria-atomic="false"
  aria-label="Notifications"
  aria-live="polite"
  class="sm-wrap"
>
  <div
    class="sm-item sm-success"
    role="alert"
  >
    <span
      aria-hidden="true"
      class="sm-icon"
    >
      ✅
    </span>
    <span
      class="sm-text"
    >
      Payment sent
    </span>
    <button
      aria-label="Retry action"
      class="sm-retry"
    >
      Retry
    </button>
    <button
      aria-label="Dismiss: Payment sent"
      class="sm-close"
    >
      ✕
    </button>
  </div>
</div>
`;
