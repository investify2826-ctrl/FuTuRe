exports[`Input snapshots > renders input with error 1`] = `
<div
  class="input-wrap"
>
  <label
    class="input-label"
    for="email"
  >
    Email
  </label>
  <input
    aria-describedby="email-error"
    aria-invalid="true"
    class="input-field input-error"
    id="email"
  />
  <span
    class="input-error-msg"
    id="email-error"
    role="alert"
  >
    Invalid email format
  </span>
</div>
`;

