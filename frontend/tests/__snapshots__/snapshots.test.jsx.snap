exports[`AmountInput snapshots > renders default state 1`] = `
<div
  style="display: flex; gap: 8px; align-items: center;"
>
  <div
    style="position: relative; flex: 1 1 0%;"
  >
    <input
      aria-label="Amount"
      inputmode="decimal"
      placeholder="0.0000000"
      style="padding-right: 10px;"
      type="text"
      value=""
    />
  </div>
  <select
    aria-label="Currency"
    style="border: 1px solid rgb(221, 221, 221); border-radius: 4px; padding: 10px 8px; font-size: 14px; background: white; cursor: pointer; min-height: 44px;"
  >
    <option
      title="Stellar Lumens"
      value="XLM"
    >
      XLM
    </option>
    <option
      title="USD Coin"
      value="USDC"
    >
      USDC
    </option>
    <option
      title="Bitcoin"
      value="BTC"
    >
      BTC
    </option>
  </select>
</div>
`;

