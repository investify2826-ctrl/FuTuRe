exports[`ErrorBoundary snapshots > renders error UI when error is thrown 1`] = `
<div
  role="alert"
  style="padding: 20px 16px; margin: 16px 0px; background: rgb(254, 242, 242); border: 1px solid rgb(252, 165, 165); border-radius: 6px; text-align: center;"
>
  <span
    style="font-size: 2rem;"
  >
    ⚠️
  </span>
  <p
    style="font-weight: 600; margin: 8px 0px 4px; color: rgb(185, 28, 28);"
  >
    Something went wrong
  </p>
  <p
    style="font-size: 13px; color: rgb(127, 29, 29); margin-bottom: 12px; word-break: break-word;"
  >
    Test error
  </p>
  <button
    style="background: rgb(0, 102, 204); color: rgb(255, 255, 255); border: medium; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-size: 14px;"
  >
    Try again
  </button>
</div>
`;

