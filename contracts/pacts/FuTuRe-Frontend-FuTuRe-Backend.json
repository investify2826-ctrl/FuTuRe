{
  "consumer": {
    "name": "FuTuRe-Frontend"
  },
  "interactions": [
    {
      "description": "a health check request",
      "providerStates": [
        {
          "name": "server is running"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/health"
      },
      "response": {
        "body": {
          "status": "ok"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to create a new account",
      "providerStates": [
        {
          "name": "stellar service is available"
        }
      ],
      "request": {
        "method": "POST",
        "path": "/api/stellar/account/create"
      },
      "response": {
        "body": {
          "publicKey": "GABC123",
          "secretKey": "SABC123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.publicKey": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.secretKey": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to get account balance",
      "providerStates": [
        {
          "name": "account exists on testnet"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/stellar/account/GABC1234567890ABCDEF"
      },
      "response": {
        "body": {
          "balances": [
            {
              "asset_type": "native",
              "balance": "100.0000000"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.balances": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.balances[*].asset_type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.balances[*].balance": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to get transaction history",
      "providerStates": [
        {
          "name": "account has transaction history"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/stellar/account/GABC1234567890ABCDEF/transactions"
      },
      "response": {
        "body": {
          "transactions": [
            {
              "created_at": "2026-01-01T00:00:00Z",
              "hash": "abc123hash",
              "id": "123456789",
              "ledger": "12345",
              "operation_count": 1,
              "source_account": "GABC123",
              "successful": true
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.transactions": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.transactions[*].created_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactions[*].hash": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactions[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactions[*].ledger": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactions[*].operation_count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "$.transactions[*].source_account": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactions[*].successful": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to send a payment",
      "providerStates": [
        {
          "name": "source account has sufficient balance"
        }
      ],
      "request": {
        "body": {
          "amount": "10",
          "destination": "GDEST123",
          "sourceSecret": "SABC123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.destination": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.sourceSecret": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/stellar/payment/send"
      },
      "response": {
        "body": {
          "hash": "abc123txhash",
          "successful": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.hash": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.successful": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "FuTuRe-Backend"
  }
}