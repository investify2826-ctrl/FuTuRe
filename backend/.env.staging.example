# Backend environment configuration — staging
#
# Copy to `.env.staging` and fill in real values before deploying:
#   cp .env.staging.example .env.staging
#
# Staging mirrors production configuration as closely as possible while
# pointing at the Stellar testnet and a dedicated staging database.

APP_ENV=staging
CONFIG_VERSION=1
CONFIG_WATCH=false

# Server
PORT=3001
# Required in staging — set to your staging frontend URL(s)
ALLOWED_ORIGINS=https://staging.futureremit.app

# Stellar — testnet in staging so real funds are never at risk
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
ASSET_ISSUER=

# Fee Bump
PLATFORM_FEE_ACCOUNT_SECRET=REPLACE_WITH_STAGING_PLATFORM_SECRET
FEE_BUMP_THRESHOLD_XLM=2

# Payment Streaming — required; generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STREAM_SECRET_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# Security — required; must not be the default value
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# MFA encryption
MFA_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# OAuth2 — use staging OAuth app credentials
GOOGLE_CLIENT_ID=REPLACE_WITH_STAGING_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_STAGING_GOOGLE_CLIENT_SECRET

SERVER_BASE_URL=https://api-staging.futureremit.app
FRONTEND_BASE_URL=https://staging.futureremit.app

# Database — dedicated staging database
DATABASE_URL=postgresql://staging_user:REPLACE_WITH_PASSWORD@staging-db-host:5432/future_remittance_staging?connection_limit=25&pool_timeout=10
DB_POOL_MAX=25
DB_QUERY_TIMEOUT_MS=5000

# Logging — structured JSON for aggregation in staging
LOG_LEVEL=info

# KYC
KYC_LARGE_TRANSACTION_LIMIT=1000

# Sanctions screening
SANCTIONS_API_KEY=REPLACE_WITH_STAGING_API_KEY
SANCTIONS_API_URL=https://api.ofac-api.com/v4/search
SANCTIONS_MIN_SCORE=85

# AML thresholds
AML_LARGE_TX_THRESHOLD=10000
AML_STRUCTURING_THRESHOLD=1000
AML_STRUCTURING_COUNT=3
AML_VELOCITY_LIMIT=10000

# Rate limiting — stricter than development
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE="Too many requests, please try again later"
RATE_LIMIT_WHITELIST=

# Performance monitoring
PERF_ALERT_RESPONSE_MS=2000
PERF_ALERT_ERROR_RATE=0.1

# Redis — required for distributed session/cache in staging
REDIS_URL=redis://staging-redis-host:6379

# CDN
CDN_ENABLED=true
CDN_URL=https://cdn-staging.futureremit.app
CDN_REGIONS=us-east-1
CDN_CACHE_MAX_AGE_S=86400

# Cache TTLs
CACHE_TTL_BALANCE_S=30
RATE_CACHE_TTL_S=60
CACHE_TTL_FEE_S=120

# Backup
BACKUP_DIR=/var/backups/future-staging
BACKUP_ENC_KEY=REPLACE_WITH_64_CHAR_HEX
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_HOURS=24

# Alerting
ALERT_EMAIL=staging-alerts@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/STAGING_WEBHOOK

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-staging:4318
